<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="QA Automation Suite">

    <listeners>
        <listener class-name="com.durvesh.listeners.RetryTransformer"/>
    </listeners>

    <!-- Browser Parameter -->
    <parameter name="browser" value="chrome"/>

    <test name="Login Tests">

        <classes>
            <class name="com.durvesh.tests.LoginTest"/>
        </classes>

    </test>

</suite>